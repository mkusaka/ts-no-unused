{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  minimumReleaseAge: "7 days",
  extends: ["config:best-practices", "group:definitelyTyped"],
  rangeStrategy: "bump",
  prConcurrentLimit: 0,
  prHourlyLimit: 0,
  commitBodyTable: true,
  dependencyDashboard: true,
  postUpdateOptions: ["pnpmDedupe"],
  platformAutomerge: false,
  customManagers: [
    {
      customType: "regex",
      description: "Update tool versions pinned in workflow-lint.yml and release.yml",
      managerFilePatterns: [
        "/^\\.github/workflows/workflow-lint\\.yml$/",
        "/^\\.github/workflows/release\\.yml$/",
      ],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: (?:lookupName|packageName)=(?<packageName>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: registryUrl=(?<registryUrl>[^\\s]+?))?\\s+[A-Za-z0-9_]+?_VERSION\\s*:\\s*[\"']?(?<currentValue>.+?)[\"']?\\s",
        "version: (?<currentValue>v?\\d+\\.\\d+\\.\\d+) # renovate: depName=(?<depName>\\S+)",
      ],
      datasourceTemplate: "github-releases",
      versioningTemplate: "semver",
    },
  ],
  packageRules: [
    {
      description: "Group minor, patch, and pin updates for production npm dependencies",
      groupName: "dependencies (non-major)",
      matchManagers: ["npm"],
      matchDepTypes: ["dependencies"],
      matchUpdateTypes: ["minor", "patch", "pin"],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
    },
    {
      description: "Group minor, patch, and pin updates for development npm dependencies",
      groupName: "devDependencies (non-major)",
      matchManagers: ["npm"],
      matchDepTypes: ["devDependencies"],
      matchUpdateTypes: ["minor", "patch", "pin"],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
    },
    {
      description: "Group minor, patch, digest, and pinDigest updates for GitHub Actions",
      groupName: "github-actions (non-major)",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor", "patch", "digest", "pinDigest"],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
    },
    {
      description: "Group minor, patch, and pin updates for workflow tooling",
      groupName: "workflow tooling (non-major)",
      matchManagers: ["custom.regex"],
      matchUpdateTypes: ["minor", "patch", "pin"],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
    },
  ],
}
